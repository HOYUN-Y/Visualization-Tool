{
  "name": "insight-analytics-workbench",
  "version": "1.0.0",
  "private": true,
  "description": "No-build browser BI tool. This package.json exists only for the test harness (Node unit tests + Playwright E2E); the app itself has no build step.",
  "type": "commonjs",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "bump": "bash scripts/bump-assets.sh",
    "build": "node scripts/build.mjs",
    "preview": "node scripts/build.mjs && (cd dist && python3 -m http.server 8743)",
    "verify:dist": "node scripts/verify-dist.mjs"
  },
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1"
  }
}
